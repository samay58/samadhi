{
  "indentation": {
    "spaces": 4
  },
  "lineLength": 120,
  "maximumBlankLines": 1,
  "multiElementCollectionTrailingCommas": true,
  "rules": {
    "AllPublicDeclarationsHaveDocumentation": false,
    "NeverForceUnwrap": true,
    "NeverUseForceTry": true,
    "OrderedImports": true
  },
  "version": 1
}
